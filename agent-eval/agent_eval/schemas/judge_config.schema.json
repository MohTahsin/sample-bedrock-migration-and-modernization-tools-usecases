{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Judge Configuration",
  "description": "Schema for judge configuration (1-5 judges required)",
  "type": "object",
  "required": ["judges"],
  "additionalProperties": false,
  "properties": {
    "judges": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "description": "List of judge configurations (1-5 judges)",
      "items": {
        "type": "object",
        "required": ["judge_id", "provider", "model_id", "params"],
        "additionalProperties": false,
        "properties": {
          "judge_id": {
            "type": "string",
            "description": "Unique identifier for this judge"
          },
          "provider": {
            "type": "string",
            "description": "LLM provider (e.g., openai, anthropic, bedrock)"
          },
          "model_id": {
            "type": "string",
            "description": "Model identifier (e.g., gpt-4, claude-3-opus)"
          },
          "params": {
            "type": "object",
            "description": "Model-specific parameters (temperature, max_tokens, etc.)",
            "additionalProperties": true
          },
          "repeats": {
            "type": "integer",
            "minimum": 1,
            "default": 3,
            "description": "Number of times to repeat each evaluation (default: 3)"
          },
          "concurrency": {
            "type": "integer",
            "minimum": 1,
            "description": "Optional concurrency limit for this judge"
          },
          "rate_limit": {
            "type": "integer",
            "minimum": 1,
            "description": "Optional rate limit (requests per second)"
          },
          "retry_policy": {
            "type": "object",
            "description": "Optional retry policy configuration",
            "properties": {
              "max_retries": {
                "type": "integer",
                "minimum": 0,
                "default": 3
              },
              "backoff_multiplier": {
                "type": "number",
                "minimum": 1,
                "default": 2
              }
            }
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 1,
            "default": 30,
            "description": "Timeout for each judge call in seconds"
          }
        }
      }
    }
  }
}
