    {
      "id": "efficiency",
      "name": "Efficiency",
      "description": "Cost and token efficiency ratios per request",
      "widgets": [
        {
          "widget_id": "cost_per_request",
          "type": "timeseries",
          "title": "Cost per Request ($)",
          "metrics": ["InputTokensCost", "OutputTokensCost", "InvocationSuccess"],
          "dimensions": ["InferenceProfile"],
          "stat": "Sum",
          "available_stats": ["Sum", "Average"],
          "period": 300,
          "available_periods": [60, 300, 3600, 86400],
          "analysis": null,
          "available_analysis": ["none", "trend", "anomaly_detection", "arima"],
          "position": {"x": 0, "y": 0, "w": 12, "h": 6},
          "use_search": false,
          "stacked": false,
          "expression": "(itc + otc) / inv",
          "metric_ids": {"InputTokensCost": "itc", "OutputTokensCost": "otc", "InvocationSuccess": "inv"}
        },
        {
          "widget_id": "tokens_per_request",
          "type": "timeseries",
          "title": "Tokens per Request",
          "metrics": ["InputTokens", "OutputTokens", "InvocationSuccess"],
          "dimensions": ["InferenceProfile"],
          "stat": "Sum",
          "available_stats": ["Sum", "Average"],
          "period": 300,
          "available_periods": [60, 300, 3600, 86400],
          "analysis": null,
          "available_analysis": ["none", "trend", "anomaly_detection", "arima"],
          "position": {"x": 12, "y": 0, "w": 12, "h": 6},
          "use_search": false,
          "stacked": false,
          "expression": "(it + ot) / inv",
          "metric_ids": {"InputTokens": "it", "OutputTokens": "ot", "InvocationSuccess": "inv"}
        },
        {
          "widget_id": "input_output_ratio",
          "type": "timeseries",
          "title": "Output / Input Token Ratio",
          "metrics": ["InputTokens", "OutputTokens"],
          "dimensions": ["InferenceProfile"],
          "stat": "Sum",
          "available_stats": ["Sum", "Average"],
          "period": 300,
          "available_periods": [60, 300, 3600, 86400],
          "analysis": null,
          "available_analysis": ["none", "trend", "anomaly_detection"],
          "position": {"x": 0, "y": 6, "w": 12, "h": 6},
          "use_search": false,
          "stacked": false,
          "expression": "ot / it",
          "metric_ids": {"InputTokens": "it", "OutputTokens": "ot"}
        },
        {
          "widget_id": "output_tokens_per_dollar",
          "type": "timeseries",
          "title": "Output Tokens per Dollar",
          "metrics": ["OutputTokens", "InputTokensCost", "OutputTokensCost"],
