  "templates": [
    {
      "id": "cost_overview",
      "name": "Cost Overview",
      "description": "Token costs by profile with cross-profile comparison",
      "widgets": [
        {
          "widget_id": "cost_timeseries",
          "type": "timeseries",
          "title": "Token Costs",
          "metrics": ["InputTokensCost", "OutputTokensCost"],
          "dimensions": ["InferenceProfile"],
          "stat": "Sum",
          "available_stats": ["Sum", "Average", "Minimum", "Maximum", "p50", "p90", "p99"],
          "period": 300,
          "available_periods": [60, 300, 3600, 86400],
          "analysis": null,
          "available_analysis": ["none", "trend", "anomaly_detection", "arima"],
          "position": {"x": 0, "y": 0, "w": 12, "h": 6},
          "use_search": false,
          "stacked": false
        },
        {
          "widget_id": "cost_comparison_bar",
          "type": "bar",
          "title": "All Profiles Cost Comparison",
          "metrics": ["InputTokensCost", "OutputTokensCost"],
          "dimensions": ["InferenceProfile"],
          "stat": "Sum",
          "available_stats": ["Sum", "Average", "Minimum", "Maximum"],
          "period": 300,
          "available_periods": [60, 300, 3600, 86400],
          "analysis": null,
          "available_analysis": ["none", "trend"],
          "use_search": true,
          "stacked": true,
          "position": {"x": 12, "y": 0, "w": 12, "h": 6}
